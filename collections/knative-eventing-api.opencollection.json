          "http": {
            "method": "DELETE",
            "url": "https://kubernetes.default.svc/apis/messaging.knative.dev/v1/namespaces/:namespace/channels/:name",
            "params": [
              {
                "name": "namespace",
                "value": "",
                "type": "path",
                "description": "Kubernetes namespace containing the resource."
